        NoteWidth: 200
        LocalizedNoteText:
          Translations:
          - LanguageID: RU
            Text: "Branch \u0441\u043E\u0437\u0434\u0430\u0435\u0442 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0435
              \u0432\u0430\u0440\u0438\u0430\u043D\u0442\u044B \u043E\u0442\u0432\u0435\u0442\u043E\u0432.
              \u041D\u043E \u0435\u0441\u043B\u0438 \u0432\u044B \u0445\u043E\u0442\u0438\u0442\u0435
              \u0434\u043E\u0431\u0430\u0432\u0438\u0442\u044C \u0430\u0437\u0430\u0440\u0442\u0430,
              \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439\u0442\u0435
              Random!"
          - LanguageID: EN
            Text: Branch creates classic dialogue choices. But if you want to add
              excitement, use Random!
