        NoteWidth: 698
        LocalizedNoteText:
          Translations:
          - LanguageID: RU
            Text: "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C
              \u0432 <color=#FFCC66>Novella Engine</color>!\n\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439
              \u043A\u043E\u043B\u0435\u0441\u0438\u043A\u043E \u043C\u044B\u0448\u0438
              \u0434\u043B\u044F \u0437\u0443\u043C\u0430, \u0430 \u0441\u0440\u0435\u0434\u043D\u044E\u044E
              \u043A\u043D\u043E\u043F\u043A\u0443 (\u0438\u043B\u0438 Alt + \u041B\u041A\u041C)
              \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0435\u043D\u0438\u044F
              \u043F\u043E \u0433\u0440\u0430\u0444\u0443.\n\n<i>\u041A\u0441\u0442\u0430\u0442\u0438,
              \u0435\u0441\u043B\u0438 \u0432\u044B \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u0442\u0435
              \u044F\u0437\u044B\u043A \u043F\u0440\u0435\u0432\u044C\u044E \u0441\u0432\u0435\u0440\u0445\u0443,
              \u0432\u044B \u0441\u043C\u043E\u0436\u0435\u0442\u0435 \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
              \u0437\u0430\u043C\u0435\u0442\u043A\u0438 \u0438 \u0434\u0438\u0430\u043B\u043E\u0433\u0438
              \u043D\u0430 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u043C
              \u044F\u0437\u044B\u043A\u0435!</i>\n\nBy the way, if you switch the
              preview language at the top panel, you will be able to view these notes
              and dialogues in English!"
          - LanguageID: EN
            Text: "Welcome to <color=#FFCC66>Novella Engine</color>!\nUse the mouse
              wheel to zoom, and the middle mouse button (or Alt + LMB) to pan across
              the graph.\n\n<i>If you switch the preview language at the top, you
              will be able to view the notes and dialogues in Russian!</i>\n\n\u041A\u0441\u0442\u0430\u0442\u0438,
              \u0435\u0441\u043B\u0438 \u0432\u044B \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u0442\u0435
              \u044F\u0437\u044B\u043A \u043F\u0440\u0435\u0432\u044C\u044E \u043D\u0430
              \u0432\u0435\u0440\u0445\u043D\u0435\u0439 \u043F\u0430\u043D\u0435\u043B\u0438,
              \u0432\u044B \u0441\u043C\u043E\u0436\u0435\u0442\u0435 \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
              \u044D\u0442\u0438 \u0437\u0430\u043C\u0435\u0442\u043A\u0438 \u0438
              \u0434\u0438\u0430\u043B\u043E\u0433\u0438 \u043D\u0430 \u0440\u0443\u0441\u0441\u043A\u043E\u043C
              \u044F\u0437\u044B\u043A\u0435!"
