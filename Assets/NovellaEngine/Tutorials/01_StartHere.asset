        NoteWidth: 293
        LocalizedNoteText:
          Translations:
          - LanguageID: RU
            Text: "\u0421\u0434\u0435\u043B\u0430\u0439\u0442\u0435 \u0442\u0430\u043A,
              \u0447\u0442\u043E\u0431\u044B \u043E\u0431\u044B\u0447\u043D\u044B\u0439
              \u0434\u0438\u0430\u043B\u043E\u0433 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B\u0441\u044F
              \u043A\u0430\u043A \u043E\u0431\u044B\u0447\u043D\u043E, \u043D\u043E
              \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u043E
              \u0434\u043E\u0431\u0430\u0432\u044C\u0442\u0435 \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0443
              Condition (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440: \u0435\u0441\u043B\u0438
              \u0410\u043B\u043C\u0430\u0437\u043E\u0432 \u2265 1). \u0415\u0441\u043B\u0438
              \u0443\u0441\u043B\u043E\u0432\u0438\u0435 \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u043E,
              \u0441\u0432\u044F\u0436\u0438\u0442\u0435 \u043D\u043E\u0434\u0443
              \u0441 \u0441\u0435\u043A\u0440\u0435\u0442\u043D\u044B\u043C \u0434\u0438\u0430\u043B\u043E\u0433\u043E\u043C,
              \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0438\u0433\u0440\u043E\u043A
              \u0438\u043D\u0430\u0447\u0435 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
              \u0431\u044B \u043D\u0435 \u0443\u0432\u0438\u0434\u0435\u043B!"
          - LanguageID: EN
            Text: "Let the normal dialogue progress as usual, but add a Condition
              check in parallel (for example: if Diamonds \u2265 1). If the condition
              is met, connect the node to a secret dialogue that the player would
              otherwise never see!"
