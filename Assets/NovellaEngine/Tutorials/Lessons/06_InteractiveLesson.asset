  m_Script: {fileID: 11500000, guid: ecfc4cf346c53c810b20578d07c03000, type: 3}
  m_Name: 06_InteractiveLesson
  m_EditorClassIdentifier: Assembly-CSharp-Editor::NovellaEngine.Editor.Tutorials.NovellaTutorialAsset
  TutorialKey: InteractiveLesson
  TitleEN: Interactive Lesson
  TitleRU: "\u0418\u043D\u0442\u0435\u0440\u0430\u043A\u0442\u0438\u0432\u043D\u044B\u0439
    \u0423\u0440\u043E\u043A"
  DescriptionEN: Open a real example graph and see all systems working together.
  DescriptionRU: "\u041E\u0442\u043A\u0440\u043E\u0435\u043C \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u0439
    \u0433\u0440\u0430\u0444-\u043F\u0440\u0438\u043C\u0435\u0440 \u0438 \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438\u043C
    \u0432\u0441\u0435 \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u0432\u043C\u0435\u0441\u0442\u0435."
  Icon: "\u25B6"
  OrderIndex: 6
  HostWindow: 12
  Steps:
  - TitleEN: Welcome to the Interactive Lesson!
    TitleRU: "\u0418\u043D\u0442\u0435\u0440\u0430\u043A\u0442\u0438\u0432\u043D\u044B\u0439
      \u0423\u0440\u043E\u043A"
    BodyEN: "Take a close look at this graph and see how nodes are connected. <b>Dialogue
      \u2192 Branch \u2192 Audio \u2192 End</b> \u2014 all working together."
    BodyRU: "\u0412\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u043E \u0438\u0437\u0443\u0447\u0438
      \u0433\u0440\u0430\u0444 \u0438 \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438,
      \u043A\u0430\u043A \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u044B \u043D\u043E\u0434\u044B.
      <b>\u0414\u0438\u0430\u043B\u043E\u0433 \u2192 \u0420\u0430\u0437\u0432\u0438\u043B\u043A\u0430
      \u2192 \u0410\u0443\u0434\u0438\u043E \u2192 \u041A\u043E\u043D\u0435\u0446</b>
      \u2014 \u0432\u0441\u0451 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
      \u0432\u043C\u0435\u0441\u0442\u0435."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: 0
      y: 0
      width: 1
      height: 0.1
    ManualRectUsePercent: 1
    TargetPadding: 6
    HintStyle: 4
    AccentColor: {r: 0.36, g: 0.75, b: 0.92, a: 1}
