  m_Script: {fileID: 11500000, guid: ecfc4cf346c53c810b20578d07c03000, type: 3}
  m_Name: 02_CharacterEditor
  m_EditorClassIdentifier: Assembly-CSharp-Editor::NovellaEngine.Editor.Tutorials.NovellaTutorialAsset
  TutorialKey: CharacterEditor
  TitleEN: Actors & Variables
  TitleRU: "Персонажи и Переменные"
  DescriptionEN: Make actors with multi-layer Paper Dolls (clothes / emotions) and global story variables.
  DescriptionRU: "Создаём персонажей с многослойными Paper Dolls (одежда/эмоции) и глобальные переменные сюжета."
  Icon: "\U0001F9B8"
  OrderIndex: 2
  HostWindow: 1
  Steps:
  - TitleEN: "Actors — Who Speaks Your Story"
    TitleRU: "Актёры — кто рассказывает историю"
    BodyEN: "An <b>Actor</b> is any character that can speak, appear on screen, or be referenced in dialogue. The protagonist, side characters, even the narrator — all actors.\n\nFor each actor you'll define:\n• A <b>name</b> + portrait (shown in dialogue boxes)\n• <b>Emotions</b> — different facial sprites (happy, sad, angry…)\n• <b>Outfits</b> — full-body sprites or layered Paper Doll parts\n\nNo coding. Just art + a few clicks."
    BodyRU: "<b>Актёр</b> — это любой персонаж, который может говорить, появляться на экране или упоминаться в диалоге. Протагонист, второстепенные, даже рассказчик — все актёры.\n\nДля каждого актёра нужно задать:\n• <b>Имя</b> + портрет (рисуется в окне диалога)\n• <b>Эмоции</b> — разные спрайты лица (радость, грусть, злость…)\n• <b>Наряды</b> — полные спрайты или слои Paper Doll\n\nКода не нужно. Только арт и пара кликов."
    TargetMode: 0
    TargetName:
    ReflectionFieldName:
    ManualRect:
      serializedVersion: 2
      x: 0
      y: 0
      width: 0
      height: 0
    ManualRectUsePercent: 1
    TargetPadding: 6
    HintStyle: 4
    AccentColor: {r: 0.55, g: 0.4, b: 0.95, a: 1}
    PanelAnchor: 5
    Video: {fileID: 0}
    Image: {fileID: 0}
    ImageFPS: 12
