  - TitleEN: Characters Database
    TitleRU: "\u0411\u0430\u0437\u0430 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435\u0439"
    BodyEN: This is your <b>characters database</b>. Click <b>+ Create New Character</b>
      at the top to add your first actor.
    BodyRU: "\u042D\u0442\u043E <b>\u0431\u0430\u0437\u0430 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435\u0439</b>.
      \u041D\u0430\u0436\u043C\u0438 <b>+ \u0421\u043E\u0437\u0434\u0430\u0442\u044C
      \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430</b> \u0441\u0432\u0435\u0440\u0445\u0443,
      \u0447\u0442\u043E\u0431\u044B \u0434\u043E\u0431\u0430\u0432\u0438\u0442\u044C
      \u043F\u0435\u0440\u0432\u043E\u0433\u043E \u0430\u043A\u0442\u0451\u0440\u0430."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: 0
      y: 0.05
      width: 0.22
      height: 0.92
    ManualRectUsePercent: 1
