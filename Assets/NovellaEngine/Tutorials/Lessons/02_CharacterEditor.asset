  m_Script: {fileID: 11500000, guid: ecfc4cf346c53c810b20578d07c03000, type: 3}
  m_Name: 02_CharacterEditor
  m_EditorClassIdentifier: Assembly-CSharp-Editor::NovellaEngine.Editor.Tutorials.NovellaTutorialAsset
  TutorialKey: CharacterEditor
  TitleEN: Actors & Variables
  TitleRU: "\u041F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0438 \u0438 \u041F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435"
  DescriptionEN: Define actors, multi-layered Paper Dolls, and global variables.
  DescriptionRU: "\u0421\u043E\u0437\u0434\u0430\u0434\u0438\u043C \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435\u0439
    \u0441 \u043C\u043D\u043E\u0433\u043E\u0441\u043B\u043E\u0439\u043D\u043E\u0439
    \u0433\u0440\u0430\u0444\u0438\u043A\u043E\u0439 \u0438 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435."
  Icon: "\U0001F9B8"
  OrderIndex: 2
  HostWindow: 1
  Steps:
  - TitleEN: Welcome to Characters Module
    TitleRU: "\u041C\u043E\u0434\u0443\u043B\u044C \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435\u0439"
    BodyEN: Create, manage and edit all your story actors here. <i>Main Characters</i>
      and <i>Favorites</i> are auto-grouped at the top so you can find them instantly.
    BodyRU: "\u0421\u043E\u0437\u0434\u0430\u0432\u0430\u0439, \u0440\u0435\u0434\u0430\u043A\u0442\u0438\u0440\u0443\u0439
      \u0438 \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0439 \u0432\u0441\u0435\u043C\u0438
      \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430\u043C\u0438 \u0437\u0434\u0435\u0441\u044C.
      <i>\u0413\u043B\u0430\u0432\u043D\u044B\u0435 \u0433\u0435\u0440\u043E\u0438</i>
      \u0438 <i>\u0418\u0437\u0431\u0440\u0430\u043D\u043D\u044B\u0435</i> \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
      \u0433\u0440\u0443\u043F\u043F\u0438\u0440\u0443\u044E\u0442\u0441\u044F \u0441\u0432\u0435\u0440\u0445\u0443
      \u0441\u043F\u0438\u0441\u043A\u0430."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: 0
