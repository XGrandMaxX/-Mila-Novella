  - TitleEN: Paper Doll System
    TitleRU: "\u0421\u0438\u0441\u0442\u0435\u043C\u0430 \u0441\u043B\u043E\u0451\u0432
      (Paper Doll)"
    BodyEN: "Build characters <b>layer by layer</b>: Body \u2192 Clothes \u2192 Face
      \u2192 Hair \u2192 Accessories. Re-order with \u25B2\u25BC buttons. Each layer
      can have its own offset, scale and tint."
    BodyRU: "\u0421\u043E\u0431\u0438\u0440\u0430\u0439 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435\u0439
      \u043F\u043E <b>\u0441\u043B\u043E\u044F\u043C</b>: \u0422\u0435\u043B\u043E
      \u2192 \u041E\u0434\u0435\u0436\u0434\u0430 \u2192 \u041B\u0438\u0446\u043E
      \u2192 \u0412\u043E\u043B\u043E\u0441\u044B \u2192 \u0410\u043A\u0441\u0435\u0441\u0441\u0443\u0430\u0440\u044B.
      \u041A\u043D\u043E\u043F\u043A\u0438 \u25B2\u25BC \u043C\u0435\u043D\u044F\u044E\u0442
      \u043F\u043E\u0440\u044F\u0434\u043E\u043A. \u0423 \u043A\u0430\u0436\u0434\u043E\u0433\u043E
      \u0441\u043B\u043E\u044F \u0441\u0432\u043E\u0439 \u0441\u0434\u0432\u0438\u0433,
      \u043C\u0430\u0441\u0448\u0442\u0430\u0431 \u0438 \u043E\u0442\u0442\u0435\u043D\u043E\u043A."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: 0.22
      y: 0.3
      width: 0.34
      height: 0.45
    ManualRectUsePercent: 1
    TargetPadding: 6
