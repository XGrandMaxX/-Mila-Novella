  m_Script: {fileID: 11500000, guid: ecfc4cf346c53c810b20578d07c03000, type: 3}
  m_Name: 05_UIEditor
  m_EditorClassIdentifier: Assembly-CSharp-Editor::NovellaEngine.Editor.Tutorials.NovellaTutorialAsset
  TutorialKey: UIEditor
  TitleEN: UI Forge
  TitleRU: "\u041A\u0443\u0437\u043D\u0438\u0446\u0430 UI"
  DescriptionEN: Style dialogue frames, main menu and character wardrobe.
  DescriptionRU: "\u0421\u0442\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u044F \u0434\u0438\u0430\u043B\u043E\u0433\u043E\u0432,
    \u043C\u0435\u043D\u044E \u0438 \u0433\u0430\u0440\u0434\u0435\u0440\u043E\u0431\u0430
    \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430."
  Icon: "\U0001F3A8"
  OrderIndex: 5
  HostWindow: 3
  Steps:
  - TitleEN: Welcome to UI Forge
    TitleRU: "\u041A\u0443\u0437\u043D\u0438\u0446\u0430 UI"
    BodyEN: "Design every visual aspect of your game directly inside the Studio.
      Tip: for advanced custom UI, learn Unity Canvas \u2014 UI Forge is a great
      starting point but it's basic."
    BodyRU: "\u0417\u0434\u0435\u0441\u044C \u043D\u0430\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0435\u0442\u0441\u044F
      \u0432\u0435\u0441\u044C \u0432\u0438\u0437\u0443\u0430\u043B \u0438\u0433\u0440\u044B
      \u043F\u0440\u044F\u043C\u043E \u0432\u043D\u0443\u0442\u0440\u0438 \u0421\u0442\u0443\u0434\u0438\u0438.
      \u0421\u043E\u0432\u0435\u0442: \u0434\u043B\u044F \u0441\u043B\u043E\u0436\u043D\u043E\u0433\u043E
      \u043A\u0430\u0441\u0442\u043E\u043C\u043D\u043E\u0433\u043E UI \u0438\u0437\u0443\u0447\u0438
      Unity Canvas \u2014 \u041A\u0443\u0437\u043D\u0438\u0446\u0430 UI \u2014 \u043E\u0442\u043B\u0438\u0447\u043D\u044B\u0439
      \u0441\u0442\u0430\u0440\u0442, \u043D\u043E \u0431\u0430\u0437\u043E\u0432\u044B\u0439
      \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: 0
      y: 0
      width: 1
      height: 0.12
    ManualRectUsePercent: 1
    TargetPadding: 6
    HintStyle: 4
    AccentColor: {r: 0.36, g: 0.75, b: 0.92, a: 1}
