  m_Script: {fileID: 11500000, guid: ecfc4cf346c53c810b20578d07c03000, type: 3}
  m_Name: 05_UIEditor
  m_EditorClassIdentifier: Assembly-CSharp-Editor::NovellaEngine.Editor.Tutorials.NovellaTutorialAsset
  TutorialKey: UIEditor
  TitleEN: UI Forge
  TitleRU: "UI Кузница"
  DescriptionEN: Style your dialogue boxes, customize the main menu and configure the wardrobe screen — all visual, no code.
  DescriptionRU: "Стилизуй диалоги, настрой главное меню и экран гардероба — визуально, без кода."
  Icon: "\U0001F3A8"
  OrderIndex: 5
  HostWindow: 3
  Steps:
  - TitleEN: "What is UI Forge?"
    TitleRU: "Что такое UI Кузница?"
    BodyEN: "<b>UI Forge</b> is your visual UI editor — it shows your game's interface (dialogue boxes, menus, wardrobe screens) live and lets you tweak <b>colors, fonts, button positions, transitions</b> with no code.\n\nThink of it as <i>«Photoshop for your in-game UI»</i>, but with the actual game wired in. Click the <b>Play</b> button at the top right and you're playing the real game inside the editor."
    BodyRU: "<b>UI Кузница</b> — визуальный редактор интерфейса. Показывает игровой UI (диалоги, меню, гардероб) в реальном времени и даёт менять <b>цвета, шрифты, позиции кнопок, анимации</b> без кода.\n\nКак <i>«Photoshop для UI игры»</i>, но с подключённой настоящей игрой. Жми <b>Play</b> справа сверху — и играешь прямо в редакторе."
    TargetMode: 0
    TargetName:
    ReflectionFieldName:
    ManualRect:
      serializedVersion: 2
      x: 0
      y: 0
      width: 0
      height: 0
