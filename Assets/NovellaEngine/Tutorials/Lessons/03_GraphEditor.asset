  m_Script: {fileID: 11500000, guid: ecfc4cf346c53c810b20578d07c03000, type: 3}
  m_Name: 03_GraphEditor
  m_EditorClassIdentifier: Assembly-CSharp-Editor::NovellaEngine.Editor.Tutorials.NovellaTutorialAsset
  TutorialKey: GraphEditor
  TitleEN: Graph Editor
  TitleRU: "Редактор Графа"
  DescriptionEN: Write your story by connecting Dialogue, Choice, Audio, Logic and many other nodes — no scripting required.
  DescriptionRU: "Пишем историю, соединяя ноды Диалогов, Выборов, Аудио, Логики и многие другие — без кода."
  Icon: "\U0001F5FA"
  OrderIndex: 3
  HostWindow: 10
  Steps:
  - TitleEN: "What is a Story Graph?"
    TitleRU: "Что такое Граф истории?"
    BodyEN: "Your story isn't a script — it's a <b>flowchart</b>. Each box (called a <b>node</b>) is one event: a line of dialogue, a player choice, a music change, a variable update.\n\nLines between boxes show <b>what comes after what</b>. Branching is just splitting one line into two.\n\nThis is exactly how visual novel writers and game designers actually plan stories. We just removed the part where you had to translate it into code."
    BodyRU: "Твоя история — это не сценарий, а <b>блок-схема</b>. Каждый прямоугольник (<b>нода</b>) — одно событие: реплика, выбор игрока, смена музыки, изменение переменной.\n\nЛинии между нодами показывают, <b>что за чем идёт</b>. Ветвление — это просто две линии вместо одной.\n\nИменно так сценаристы новелл реально планируют истории. Мы убрали только ту часть, где это надо было переводить в код."
    TargetMode: 0
    TargetName:
    ReflectionFieldName:
    ManualRect:
      serializedVersion: 2
      x: 0
      y: 0
      width: 0
      height: 0
    ManualRectUsePercent: 1
