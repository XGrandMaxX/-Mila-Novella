    HideNextButton: 0
  - TitleEN: Node Inspector
    TitleRU: "\u0418\u043D\u0441\u043F\u0435\u043A\u0442\u043E\u0440 \u043D\u043E\u0434\u044B"
    BodyEN: <b>Click any node</b> to open its <b>Inspector</b> on the right. There
      you edit text, pick characters, attach audio and configure logic.
    BodyRU: "<b>\u041D\u0430\u0436\u043C\u0438 \u043D\u0430 \u043B\u044E\u0431\u0443\u044E
      \u043D\u043E\u0434\u0443</b>, \u0447\u0442\u043E\u0431\u044B \u043E\u0442\u043A\u0440\u044B\u0442\u044C
      \u0435\u0451 <b>\u0418\u043D\u0441\u043F\u0435\u043A\u0442\u043E\u0440</b>
      \u0441\u043F\u0440\u0430\u0432\u0430. \u0422\u0430\u043C \u043D\u0430\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0435\u0442\u0441\u044F
      \u0442\u0435\u043A\u0441\u0442, \u0432\u044B\u0431\u043E\u0440 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435\u0439,
      \u0437\u0432\u0443\u043A \u0438 \u043B\u043E\u0433\u0438\u043A\u0430."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: 0.65
      y: 0.08
      width: 0.34
      height: 0.9
    ManualRectUsePercent: 1
    TargetPadding: 6
    HintStyle: 1
    AccentColor: {r: 0.36, g: 0.75, b: 0.92, a: 1}
