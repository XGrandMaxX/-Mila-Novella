  - TitleEN: Minimap
    TitleRU: "\u041C\u0438\u043D\u0438\u043A\u0430\u0440\u0442\u0430"
    BodyEN: The <b>Minimap</b> in the bottom-left helps you navigate large story
      graphs. Click and drag inside it to jump around.
    BodyRU: "<b>\u041C\u0438\u043D\u0438\u043A\u0430\u0440\u0442\u0430</b> \u0432
      \u043B\u0435\u0432\u043E\u043C \u043D\u0438\u0436\u043D\u0435\u043C \u0443\u0433\u043B\u0443
      \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442 \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C\u0441\u044F
      \u0432 \u0431\u043E\u043B\u044C\u0448\u0438\u0445 \u0433\u0440\u0430\u0444\u0430\u0445.
      \u041A\u043B\u0438\u043A\u043D\u0438 \u0438 \u0442\u044F\u043D\u0438 \u0432\u043D\u0443\u0442\u0440\u0438
      \u043D\u0435\u0451, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u044B\u0433\u043D\u0443\u0442\u044C
      \u0432 \u043D\u0443\u0436\u043D\u043E\u0435 \u043C\u0435\u0441\u0442\u043E."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: 0.01
      y: 0.72
      width: 0.2
      height: 0.25
