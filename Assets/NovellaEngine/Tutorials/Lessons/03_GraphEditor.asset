  m_Script: {fileID: 11500000, guid: ecfc4cf346c53c810b20578d07c03000, type: 3}
  m_Name: 03_GraphEditor
  m_EditorClassIdentifier: Assembly-CSharp-Editor::NovellaEngine.Editor.Tutorials.NovellaTutorialAsset
  TutorialKey: GraphEditor
  TitleEN: Graph Editor
  TitleRU: "\u0420\u0435\u0434\u0430\u043A\u0442\u043E\u0440 \u0413\u0440\u0430\u0444\u0430"
  DescriptionEN: Connect dialogue, choices, audio and logic into your story.
  DescriptionRU: "\u0421\u043E\u0435\u0434\u0438\u043D\u044F\u0439 \u0434\u0438\u0430\u043B\u043E\u0433\u0438,
    \u0432\u044B\u0431\u043E\u0440\u044B, \u0430\u0443\u0434\u0438\u043E \u0438 \u043B\u043E\u0433\u0438\u043A\u0443
    \u0432 \u043E\u0434\u043D\u0443 \u0438\u0441\u0442\u043E\u0440\u0438\u044E."
  Icon: "\U0001F5FA"
  OrderIndex: 3
  HostWindow: 10
  Steps:
  - TitleEN: Welcome to the Graph Editor
    TitleRU: "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C
      \u0432 \u0420\u0435\u0434\u0430\u043A\u0442\u043E\u0440 \u0413\u0440\u0430\u0444\u0430"
    BodyEN: This is the <b>heart of Novella Engine</b>. Your story logic, branches
      and dialogues all live here. Each node is a step in your scenario.
    BodyRU: "\u042D\u0442\u043E <b>\u0441\u0435\u0440\u0434\u0446\u0435 Novella Engine</b>.
      \u041B\u043E\u0433\u0438\u043A\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u0438,
      \u0432\u0435\u0442\u0432\u043B\u0435\u043D\u0438\u044F \u0438 \u0434\u0438\u0430\u043B\u043E\u0433\u0438
      \u0436\u0438\u0432\u0443\u0442 \u0437\u0434\u0435\u0441\u044C. \u041A\u0430\u0436\u0434\u0430\u044F
      \u043D\u043E\u0434\u0430 \u2014 \u0448\u0430\u0433 \u0441\u0446\u0435\u043D\u0430\u0440\u0438\u044F."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: 0
      y: 0
      width: 1
      height: 0.12
    ManualRectUsePercent: 1
    TargetPadding: 6
    HintStyle: 4
    AccentColor: {r: 0.36, g: 0.75, b: 0.92, a: 1}
