  m_Script: {fileID: 11500000, guid: ecfc4cf346c53c810b20578d07c03000, type: 3}
  m_Name: 04_DLCManager
  m_EditorClassIdentifier: Assembly-CSharp-Editor::NovellaEngine.Editor.Tutorials.NovellaTutorialAsset
  TutorialKey: DLCManager
  TitleEN: DLC Modules
  TitleRU: "\u041C\u043E\u0434\u0443\u043B\u0438 DLC"
  DescriptionEN: "Expand the engine with extra mechanics \u2014 wardrobe, quests,
    inventory."
  DescriptionRU: "\u0420\u0430\u0441\u0448\u0438\u0440\u044C \u0434\u0432\u0438\u0436\u043E\u043A
    \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430\u043C\u0438 \u2014 \u0433\u0430\u0440\u0434\u0435\u0440\u043E\u0431,
    \u043A\u0432\u0435\u0441\u0442\u044B, \u0438\u043D\u0432\u0435\u043D\u0442\u0430\u0440\u044C."
  Icon: "\U0001F9E9"
  OrderIndex: 4
  HostWindow: 11
  Steps:
  - TitleEN: DLC Modules Manager
    TitleRU: "\u041C\u0435\u043D\u0435\u0434\u0436\u0435\u0440 \u043C\u043E\u0434\u0443\u043B\u0435\u0439
      DLC"
    BodyEN: "<b>DLCs</b> seamlessly add new node types to Novella Engine \u2014 wardrobes,
      mini-games, quest systems. Toggle them on or off here."
    BodyRU: "<b>DLC</b> \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u044E\u0442 \u043D\u043E\u0432\u044B\u0435
      \u0442\u0438\u043F\u044B \u043D\u043E\u0434 \u2014 \u0433\u0430\u0440\u0434\u0435\u0440\u043E\u0431\u044B,
      \u043C\u0438\u043D\u0438-\u0438\u0433\u0440\u044B, \u0441\u0438\u0441\u0442\u0435\u043C\u044B
      \u043A\u0432\u0435\u0441\u0442\u043E\u0432. \u0412\u043A\u043B\u044E\u0447\u0430\u0439
      \u0438 \u0432\u044B\u043A\u043B\u044E\u0447\u0430\u0439 \u0438\u0445 \u0437\u0434\u0435\u0441\u044C."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: 0
      y: 0
      width: 1
      height: 0.12
    ManualRectUsePercent: 1
    TargetPadding: 6
    HintStyle: 4
    AccentColor: {r: 0.36, g: 0.75, b: 0.92, a: 1}
    PanelAnchor: 0
    Video: {fileID: 0}
    Image: {fileID: 0}
    ImageFPS: 12
    ImageFrameCount: 1
    AdvanceMode: 0
    ActionTrigger: 0
    ActionTextRegex: 
    AutoAdvanceSeconds: 0
    MinHoldSeconds: 1.5
    AllowSkip: 1
    HideNextButton: 0
  - TitleEN: Open the DLC tab in the sidebar
    TitleRU: "\u041D\u0430\u0439\u0434\u0438 \u0432\u043A\u043B\u0430\u0434\u043A\u0443
      DLC \u0432 \u0441\u0430\u0439\u0434\u0431\u0430\u0440\u0435"
    BodyEN: "Look in the <b>Workspace Tools</b> panel \u2014 the <b>\U0001F9E9 DLC
      Modules</b> button is there. It's the control center for all installed extensions."
    BodyRU: "\u0421\u043C\u043E\u0442\u0440\u0438 \u0432 \u043F\u0430\u043D\u0435\u043B\u044C
      <b>\u0418\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B</b> \u0441\u043B\u0435\u0432\u0430
      \u2014 \u0442\u0430\u043C \u0435\u0441\u0442\u044C \u043A\u043D\u043E\u043F\u043A\u0430
      <b>\U0001F9E9 \u041C\u043E\u0434\u0443\u043B\u0438 DLC</b>. \u042D\u0442\u043E
      \u0446\u0435\u043D\u0442\u0440 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
      \u0432\u0441\u0435\u043C\u0438 \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u044F\u043C\u0438."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: 0.01
      y: 0.2
      width: 0.2
      height: 0.1
    ManualRectUsePercent: 1
    TargetPadding: 6
    HintStyle: 2
    AccentColor: {r: 0.36, g: 0.75, b: 0.92, a: 1}
    PanelAnchor: 0
    Video: {fileID: 0}
