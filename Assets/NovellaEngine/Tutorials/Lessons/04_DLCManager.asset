    ImageFrameCount: 1
    AdvanceMode: 0
    ActionTrigger: 0
    ActionTextRegex: 
    AutoAdvanceSeconds: 0
    MinHoldSeconds: 1.5
    AllowSkip: 1
    HideNextButton: 0
  - TitleEN: Graceful Degradation
    TitleRU: "\u0423\u043C\u043D\u044B\u0439 \u043F\u0440\u043E\u043F\u0443\u0441\u043A"
    BodyEN: "If you <b>disable a DLC</b>, the player will just <b>skip those nodes</b>
      in-game \u2014 no errors. This makes it safe to share scenarios with people
      who haven't bought the DLC."
    BodyRU: "\u0415\u0441\u043B\u0438 \u0442\u044B <b>\u043E\u0442\u043A\u043B\u044E\u0447\u0438\u0448\u044C
      DLC</b>, \u043F\u043B\u0435\u0435\u0440 <b>\u043F\u0440\u043E\u0441\u043A\u043E\u0447\u0438\u0442
      \u0435\u0433\u043E \u043D\u043E\u0434\u044B \u043D\u0430\u0441\u043A\u0432\u043E\u0437\u044C</b>
      \u0432 \u0438\u0433\u0440\u0435 \u2014 \u043D\u0438\u043A\u0430\u043A\u0438\u0445
      \u043E\u0448\u0438\u0431\u043E\u043A. \u041C\u043E\u0436\u043D\u043E \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E
      \u0434\u0435\u043B\u0438\u0442\u044C\u0441\u044F \u0441\u0446\u0435\u043D\u0430\u0440\u0438\u044F\u043C\u0438
      \u0441 \u0442\u0435\u043C\u0438, \u0443 \u043A\u043E\u0433\u043E DLC \u043D\u0435
      \u043A\u0443\u043F\u043B\u0435\u043D."
    TargetMode: 5
    TargetName: 
