    HideNextButton: 0
  - TitleEN: Project Scenes List
    TitleRU: "\u0421\u043F\u0438\u0441\u043E\u043A \u0441\u0446\u0435\u043D \u043F\u0440\u043E\u0435\u043A\u0442\u0430"
    BodyEN: "Here are <b>all scenes</b> from your Build Settings. Use the <b>+ Create
      New Scene</b> button below to add new ones \u2014 the engine will register
      them automatically."
    BodyRU: "\u0417\u0434\u0435\u0441\u044C \u0432\u0441\u0435 <b>\u0441\u0446\u0435\u043D\u044B
      \u043F\u0440\u043E\u0435\u043A\u0442\u0430</b> \u0438\u0437 Build Settings.
      \u041A\u043D\u043E\u043F\u043A\u0430 <b>+ \u0421\u043E\u0437\u0434\u0430\u0442\u044C
      \u043D\u043E\u0432\u0443\u044E \u0441\u0446\u0435\u043D\u0443</b> \u0432\u043D\u0438\u0437\u0443
      \u0434\u043E\u0431\u0430\u0432\u0438\u0442 \u043D\u043E\u0432\u0443\u044E \u2014
      \u0434\u0432\u0438\u0436\u043E\u043A \u0437\u0430\u0440\u0435\u0433\u0438\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
      \u0435\u0451 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: 0.2
      y: 0.1
      width: 0.78
      height: 0.78
