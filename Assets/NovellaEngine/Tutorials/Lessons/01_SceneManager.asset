  - TitleEN: Your Scenes List
    TitleRU: "\u0421\u043F\u0438\u0441\u043E\u043A \u0442\u0432\u043E\u0438\u0445
      \u0441\u0446\u0435\u043D"
    BodyEN: "On the left you'll always see <b>every scene in your project</b>. The
      first time you open this module it'll be empty \u2014 that's normal.\n\nThe
      little icons next to each scene tell you:\n\U0001F7E2 \u2014 added to <i>Build
      Settings</i> (will be in the final game)\n\U0001F512 \u2014 system scene (used
      by the engine, can't be deleted)\n\nClick a scene to select it \u2014 the right
      side will show what you can do with it."
    BodyRU: "\u0421\u043B\u0435\u0432\u0430 \u0432\u0441\u0435\u0433\u0434\u0430
      \u0432\u0438\u0434\u0435\u043D <b>\u0441\u043F\u0438\u0441\u043E\u043A \u0432\u0441\u0435\u0445
      \u0441\u0446\u0435\u043D \u043F\u0440\u043E\u0435\u043A\u0442\u0430</b>. \u041F\u0440\u0438
      \u043F\u0435\u0440\u0432\u043E\u043C \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0438
      \u043C\u043E\u0434\u0443\u043B\u044F \u043E\u043D \u0431\u0443\u0434\u0435\u0442
      \u043F\u0443\u0441\u0442\u043E\u0439 \u2014 \u044D\u0442\u043E \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E.\n\n\u0417\u043D\u0430\u0447\u043A\u0438
      \u0440\u044F\u0434\u043E\u043C \u0441 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u044F\u043C\u0438:\n\U0001F7E2
      \u2014 \u0434\u043E\u0431\u0430\u0432\u043B\u0435\u043D\u0430 \u0432 <i>Build
      Settings</i> (\u043F\u043E\u043F\u0430\u0434\u0451\u0442 \u0432 \u0444\u0438\u043D\u0430\u043B\u044C\u043D\u0443\u044E
      \u0438\u0433\u0440\u0443)\n\U0001F512 \u2014 \u0441\u0438\u0441\u0442\u0435\u043C\u043D\u0430\u044F
      \u0441\u0446\u0435\u043D\u0430 \u0434\u0432\u0438\u0436\u043A\u0430 (\u0443\u0434\u0430\u043B\u0438\u0442\u044C
      \u043D\u0435\u043B\u044C\u0437\u044F)\n\n\u041A\u043B\u0438\u043A \u043F\u043E
      \u0441\u0446\u0435\u043D\u0435 \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0442
      \u0435\u0451 \u2014 \u0441\u043F\u0440\u0430\u0432\u0430 \u043F\u043E\u044F\u0432\u044F\u0442\u0441\u044F
      \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
