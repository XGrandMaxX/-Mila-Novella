  - TitleEN: Create or Open
    TitleRU: "\u0421\u043E\u0437\u0434\u0430\u0442\u044C \u0438\u043B\u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u044C"
    BodyEN: "Two main actions live at the bottom of the list:\n\n<b>+ Create New
      Scene</b> \u2014 makes a fresh empty scene file in your project.\n<b>Open</b>
      \u2014 loads the selected scene so you can see it in the Unity viewport.\n\n<color=#FFC72C>Tip:</color>
      we recommend creating <b>two scenes</b> first \u2014 call one <i>Menu</i> and
      one <i>Game</i>. Then you'll set them up with one-click presets in the next
      step."
    BodyRU: "\u0414\u0432\u0430 \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
      \u2014 \u0432\u043D\u0438\u0437\u0443 \u0441\u043F\u0438\u0441\u043A\u0430:\n\n<b>+
      \u0421\u043E\u0437\u0434\u0430\u0442\u044C \u0441\u0446\u0435\u043D\u0443</b>
      \u2014 \u0434\u0435\u043B\u0430\u0435\u0442 \u043D\u043E\u0432\u044B\u0439
      \u043F\u0443\u0441\u0442\u043E\u0439 \u0444\u0430\u0439\u043B \u0441\u0446\u0435\u043D\u044B
      \u0432 \u043F\u0440\u043E\u0435\u043A\u0442\u0435.\n<b>\u041E\u0442\u043A\u0440\u044B\u0442\u044C</b>
      \u2014 \u0437\u0430\u0433\u0440\u0443\u0436\u0430\u0435\u0442 \u0432\u044B\u0431\u0440\u0430\u043D\u043D\u0443\u044E
      \u0441\u0446\u0435\u043D\u0443, \u0447\u0442\u043E\u0431\u044B \u0435\u0451
      \u0431\u044B\u043B\u043E \u0432\u0438\u0434\u043D\u043E \u0432\u043E \u0432\u044C\u044E\u043F\u043E\u0440\u0442\u0435
      Unity.\n\n<color=#FFC72C>\u0421\u043E\u0432\u0435\u0442:</color> \u0441\u0440\u0430\u0437\u0443
      \u0441\u043E\u0437\u0434\u0430\u0439 <b>\u0434\u0432\u0435 \u0441\u0446\u0435\u043D\u044B</b>
      \u2014 \u043D\u0430\u0437\u043E\u0432\u0438 \u043E\u0434\u043D\u0443 <i>Menu</i>,
      \u0432\u0442\u043E\u0440\u0443\u044E <i>Game</i>. \u041D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C
      \u0448\u0430\u0433\u0435 \u043C\u044B \u0437\u0430 \u0441\u0435\u043A\u0443\u043D\u0434\u0443
      \u043D\u0430\u0441\u0442\u0440\u043E\u0438\u043C \u0438\u0445 \u043F\u0440\u0435\u0441\u0435\u0442\u0430\u043C\u0438."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
