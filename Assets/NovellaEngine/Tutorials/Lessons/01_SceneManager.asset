  m_Script: {fileID: 11500000, guid: ecfc4cf346c53c810b20578d07c03000, type: 3}
  m_Name: 01_SceneManager
  m_EditorClassIdentifier: Assembly-CSharp-Editor::NovellaEngine.Editor.Tutorials.NovellaTutorialAsset
  TutorialKey: SceneManager
  TitleEN: Scenes & Menu
  TitleRU: "\u0421\u0446\u0435\u043D\u044B \u0438 \u041C\u0435\u043D\u044E"
  DescriptionEN: Set up Unity scenes for your gameplay and main menu.
  DescriptionRU: "\u041D\u0430\u0441\u0442\u0440\u043E\u0438\u043C Unity-\u0441\u0446\u0435\u043D\u044B
    \u0434\u043B\u044F \u0438\u0433\u0440\u044B \u0438 \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E
    \u043C\u0435\u043D\u044E."
  Icon: "\U0001F6E0"
  OrderIndex: 1
  HostWindow: 2
  Steps:
  - TitleEN: Welcome to Scene Manager
    TitleRU: "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C
      \u0432 \u041C\u0435\u043D\u0435\u0434\u0436\u0435\u0440 \u0421\u0446\u0435\u043D"
    BodyEN: "A <b>Scene</b> in Unity is like a separate level or screen. Novella
      Engine uses different scenes to keep your <b>Main Menu</b> and <b>Game</b>
      apart \u2014 this prevents UI overlap and keeps the project clean."
    BodyRU: "<b>\u0421\u0446\u0435\u043D\u0430</b> \u0432 Unity \u2014 \u044D\u0442\u043E
      \u043A\u0430\u043A \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u0439 \u0443\u0440\u043E\u0432\u0435\u043D\u044C
      \u0438\u043B\u0438 \u044D\u043A\u0440\u0430\u043D. Novella Engine \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442
      \u0440\u0430\u0437\u043D\u044B\u0435 \u0441\u0446\u0435\u043D\u044B, \u0447\u0442\u043E\u0431\u044B
      \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C <b>\u0413\u043B\u0430\u0432\u043D\u043E\u0435
      \u041C\u0435\u043D\u044E</b> \u0438 <b>\u0418\u0433\u0440\u0443</b> \u2014
      \u0442\u0430\u043A \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u044B
      \u043D\u0435 \u043D\u0430\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u044E\u0442\u0441\u044F
      \u0438 \u043F\u0440\u043E\u0435\u043A\u0442 \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F
      \u0447\u0438\u0441\u0442\u044B\u043C."
    TargetMode: 5
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: 0
      y: 0
      width: 1
      height: 0.12
    ManualRectUsePercent: 1
    TargetPadding: 6
    HintStyle: 4
    AccentColor: {r: 0.36, g: 0.75, b: 0.92, a: 1}
