  m_Script: {fileID: 11500000, guid: ecfc4cf346c53c810b20578d07c03000, type: 3}
  m_Name: 01_SceneManager
  m_EditorClassIdentifier: Assembly-CSharp-Editor::NovellaEngine.Editor.Tutorials.NovellaTutorialAsset
  TutorialKey: SceneManager
  TitleEN: Scenes & Menu
  TitleRU: "\u0421\u0446\u0435\u043D\u044B \u0438 \u041C\u0435\u043D\u044E"
  DescriptionEN: "Set up Unity scenes for your gameplay and main menu \u2014 without
    touching Unity's confusing menus."
  DescriptionRU: "\u041D\u0430\u0441\u0442\u0440\u043E\u0438\u043C Unity-\u0441\u0446\u0435\u043D\u044B
    \u0434\u043B\u044F \u0438\u0433\u0440\u044B \u0438 \u043C\u0435\u043D\u044E \u2014
    \u0431\u0435\u0437 \u043A\u043E\u043F\u0430\u043D\u0438\u044F \u0432 \u0441\u0442\u0440\u0430\u0448\u043D\u044B\u0445
    \u043D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0430\u0445 Unity."
  Icon: "\U0001F6E0"
  OrderIndex: 1
  HostWindow: 2
  Steps:
  - TitleEN: What is a Scene?
    TitleRU: "\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u0421\u0446\u0435\u043D\u0430?"
    BodyEN: "A <b>Scene</b> in Unity is just a separate screen of your game \u2014
      like a chapter or a stage. Novella always uses <b>at least two</b> scenes:\n\n\u2022
      <b>Main Menu</b> \u2014 what player sees on launch (Start Game, Continue, Settings).\n\u2022
      <b>Game Scene</b> \u2014 where the actual story plays.\n\nWe split them so
      the menu UI doesn't overlap with the game UI. Don't worry \u2014 you don't
      need to know Unity to set this up. We'll do it in one click."
    BodyRU: "<b>\u0421\u0446\u0435\u043D\u0430</b> \u0432 Unity \u2014 \u044D\u0442\u043E
      \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u0439
      \u044D\u043A\u0440\u0430\u043D \u0438\u0433\u0440\u044B, \u043A\u0430\u043A
      \u0433\u043B\u0430\u0432\u0430 \u0438\u043B\u0438 \u0443\u0440\u043E\u0432\u0435\u043D\u044C.
      Novella \u0432\u0441\u0435\u0433\u0434\u0430 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442
      <b>\u043C\u0438\u043D\u0438\u043C\u0443\u043C \u0434\u0432\u0435</b> \u0441\u0446\u0435\u043D\u044B:\n\n\u2022
      <b>\u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u041C\u0435\u043D\u044E</b>
      \u2014 \u0442\u043E, \u0447\u0442\u043E \u0432\u0438\u0434\u0438\u0442 \u0438\u0433\u0440\u043E\u043A
      \u043F\u0440\u0438 \u0437\u0430\u043F\u0443\u0441\u043A\u0435 (\u0421\u0442\u0430\u0440\u0442,
      \u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C, \u041D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0438).\n\u2022
      <b>\u0418\u0433\u0440\u043E\u0432\u0430\u044F \u0421\u0446\u0435\u043D\u0430</b>
      \u2014 \u0442\u0430\u043C \u0440\u0430\u0437\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
      \u0441\u0430\u043C\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u044F.\n\n\u041C\u044B
      \u0440\u0430\u0437\u0434\u0435\u043B\u044F\u0435\u043C \u0438\u0445, \u0447\u0442\u043E\u0431\u044B
      \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441 \u043C\u0435\u043D\u044E
      \u043D\u0435 \u043D\u0430\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u043B\u0441\u044F
      \u043D\u0430 \u0438\u0433\u0440\u043E\u0432\u043E\u0439. \u041D\u0435 \u043F\u0443\u0433\u0430\u0439\u0441\u044F
      \u2014 Unity \u0437\u043D\u0430\u0442\u044C \u043D\u0435 \u043D\u0443\u0436\u043D\u043E,
      \u0432\u0441\u0451 \u0434\u0435\u043B\u0430\u0435\u0442\u0441\u044F \u043E\u0434\u043D\u043E\u0439
      \u043A\u043D\u043E\u043F\u043A\u043E\u0439."
    TargetMode: 0
    TargetName: 
    ReflectionFieldName: 
    ManualRect:
      serializedVersion: 2
      x: -67.34
